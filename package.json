{
  "name": "yapi",
  "version": "0.6.5",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @yapi/web... build",
    "build:ui": "pnpm --filter @yapi/ui build",
    "build:vscode-webview": "pnpm --filter @yapi/vscode-webview build",
    "build:vscode-extension": "pnpm --filter yapi-extension build",
    "build:extension": "pnpm --filter yapi-extension... build",
    "package:extension": "pnpm --filter yapi-extension run vsce:package",
    "publish:extension": "pnpm --filter yapi-extension run vsce:publish",
    "publish:extension:ovsx": "pnpm --filter yapi-extension run ovsx:publish",
    "dev": "pnpm --filter @yapi/web dev",
    "dev:webview": "pnpm --filter @yapi/vscode-webview dev",
    "lint": "pnpm --filter @yapi/web lint",
    "test": "pnpm --filter @yapi/web test"
  },
  "devDependencies": {
    "next": "^16.1.1"
  }
}
