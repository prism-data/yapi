{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "watch",
			"type": "shell",
			"command": "pnpm run watch",
			"isBackground": true,
			"problemMatcher": {
				"owner": "webpack",
				"severity": "error",
				"fileLocation": "absolute",
				"pattern": {
					"regexp": "^\\[tsl\\] ERROR in (.+)\\((\\d+),(\\d+)\\)",
					"file": 1,
					"line": 2,
					"column": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\[webpack-cli\\] Compiler starting",
					"endsPattern": "^\\[webpack-cli\\] Compiler finished"
				}
			},
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "build",
			"type": "shell",
			"command": "pnpm run compile",
			"problemMatcher": "$ts-webpack",
			"group": "build"
		}
	]
}
