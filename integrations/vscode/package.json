{
  "name": "yapi-extension",
  "displayName": "yapi Official VSCode Extension",
  "description": "YAML API Testing Tool - HTTP, gRPC, GraphQL, and TCP support",
  "version": "0.7.1",
  "publisher": "yapi",
  "icon": "./images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamierpond/yapi.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.yapi",
    "workspaceContains:**/*.yapi.yml",
    "workspaceContains:**/*.yapi.yaml",
    "workspaceContains:**/yapi.config.yml",
    "workspaceContains:**/yapi.config.yaml",
    "onLanguage:yaml",
    "onCommand:yapi.runCurrent",
    "onCommand:yapi.insertExample"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "yapi.runCurrent",
        "title": "Run yapi",
        "category": "yapi",
        "icon": {
          "light": "media/sheep.svg",
          "dark": "media/sheep.svg"
        }
      },
      {
        "command": "yapi.insertExample",
        "title": "Insert Example",
        "category": "yapi"
      },
      {
        "command": "yapi.restartLanguageServer",
        "title": "Restart Language Server",
        "category": "yapi"
      }
    ],
    "keybindings": [
      {
        "command": "yapi.runCurrent",
        "key": "cmd+enter",
        "mac": "cmd+enter",
        "win": "ctrl+enter",
        "linux": "ctrl+enter",
        "when": "editorTextFocus && (resourceExtname == .yapi || resourceExtname == .yml || resourceExtname == .yaml) && resourceFilename =~ /\\.yapi/"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "yapi.runCurrent",
          "group": "navigation",
          "when": "(resourceExtname == .yapi || resourceExtname == .yml || resourceExtname == .yaml) && resourceFilename =~ /\\.yapi/"
        }
      ],
      "commandPalette": [
        {
          "command": "yapi.runCurrent",
          "when": "(resourceExtname == .yapi || resourceExtname == .yml || resourceExtname == .yaml) && resourceFilename =~ /\\.yapi/"
        }
      ]
    },
    "languages": [
      {
        "id": "yaml",
        "extensions": [
          ".yapi",
          ".yapi.yml",
          ".yapi.yaml"
        ],
        "filenames": [
          "yapi.config.yml",
          "yapi.config.yaml"
        ]
      }
    ],
    "configuration": {
      "title": "yapi",
      "properties": {
        "yapi.executablePath": {
          "type": "string",
          "default": "yapi",
          "description": "Path to the yapi executable. By default, will search for 'yapi' in PATH."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "prebuild": "pnpm --filter @yapi/vscode-webview build && pnpm run copy:webview",
    "copy:webview": "rm -rf media && mkdir -p media && cp -R ../../packages/vscode-ui/dist/. media/",
    "compile": "pnpm run prebuild && webpack",
    "watch": "webpack --watch",
    "package": "pnpm run prebuild && webpack --mode production --devtool hidden-source-map",
    "build": "pnpm run compile",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "vsce:package": "pnpm vsce package --no-dependencies",
    "vsce:publish": "pnpm vsce publish --no-dependencies",
    "ovsx:publish": "npx ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.2",
    "@yapi/vscode-webview": "workspace:*",
    "eslint": "^9.39.1",
    "ovsx": "^0.10.7",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@yapi/client": "workspace:*",
    "js-yaml": "^4.1.0",
    "vscode-languageclient": "^9.0.1"
  }
}
